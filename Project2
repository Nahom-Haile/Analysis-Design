using namespace std;

//Course object stores one line of course data from the input file.
struct Course {
    string courseNumber;
    string title;
    vector<string> prerequisites;
};

//Node used by the binary search tree.
struct Node {
    Course course;
    Node* left;
    Node* right;

    Node(const Course& aCourse) {
        course = aCourse;
        left = nullptr;
        right = nullptr;
    }
};

//Binary search tree stores courses ordered by course number.
class BinarySearchTree {
private:
    Node* root;

    //Recursively delete nodes to prevent memory leaks.
    void destroyTree(Node* node) {
        if (node != nullptr) {
            destroyTree(node->left);
            destroyTree(node->right);
            delete node;
        }
    }

    //Recursive helper for inserting a course into the tree.
    bool insertNode(Node*& node, const Course& course) {
        if (node == nullptr) {
            node = new Node(course);
            return true;
        }

        if (course.courseNumber < node->course.courseNumber) {
            return insertNode(node->left, course);
        }
        else if (course.courseNumber > node->course.courseNumber) {
            return insertNode(node->right, course);
        }

        //Duplicate course numbers are not allowed.
        return false;
    }

    //Recursive helper for searching the tree by course number.
    const Course* searchNode(Node* node, const string& courseNumber) const {
        if (node == nullptr) {
            return nullptr;
        }

        if (courseNumber == node->course.courseNumber) {
            return &(node->course);
        }
        else if (courseNumber < node->course.courseNumber) {
            return searchNode(node->left, courseNumber);
        }
        else {
            return searchNode(node->right, courseNumber);
        }
    }

    //In-order traversal prints the courses in alphanumeric order.
    void printInOrder(Node* node) const {
        if (node != nullptr) {
            printInOrder(node->left);
            cout << node->course.courseNumber << ", " << node->course.title << endl;
            printInOrder(node->right);
        }
    }

public:
    BinarySearchTree() {
        root = nullptr;
    }

    ~BinarySearchTree() {
        clear();
    }

    void clear() {
        destroyTree(root);
        root = nullptr;
    }

    bool insert(const Course& course) {
        return insertNode(root, course);
    }

    const Course* search(const string& courseNumber) const {
        return searchNode(root, courseNumber);
    }

    void printCourseList() const {
        printInOrder(root);
    }

    bool isEmpty() const {
        return root == nullptr;
    }
};

//Remove leading and trailing whitespace from a string.
string trim(const string& value) {
    size_t first = value.find_first_not_of(" \t\r\n");
    if (first == string::npos) {
        return "";
    }

    size_t last = value.find_last_not_of(" \t\r\n");
    return value.substr(first, last - first + 1);
}

//Convert course numbers to uppercase so searches are not case sensitive.
string toUpperCase(string value) {
    for (char& character : value) {
        character = static_cast<char>(toupper(static_cast<unsigned char>(character)));
    }
    return value;
}

//Split one comma-separated line into tokens.
vector<string> splitLine(const string& line) {
    vector<string> tokens;
    string token;
    stringstream stream(line);

    while (getline(stream, token, ',')) {
        tokens.push_back(trim(token));
    }

    return tokens;
}

//Search a vector of course numbers. Used while validating prerequisites.
bool courseNumberExists(const vector<string>& courseNumbers, const string& courseNumber) {
    for (const string& currentCourseNumber : courseNumbers) {
        if (currentCourseNumber == courseNumber) {
            return true;
        }
    }
    return false;
}

//Read, validate, and load course data into the binary search tree.
bool loadCourses(BinarySearchTree& courses, const string& fileName) {
    ifstream inputFile(fileName);

    if (!inputFile.is_open()) {
        cout << "Error: File could not be opened." << endl;
        return false;
    }

    vector<vector<string>> parsedLines;
    vector<string> courseNumbers;
    string line;
    int lineNumber = 0;

    //First pass: read the file line by line, validate course number and title fields, and collect course numbers for prerequisite validation.
    while (getline(inputFile, line)) {
        lineNumber++;
        line = trim(line);

        if (line.empty()) {
            continue;
        }

        vector<string> tokens = splitLine(line);

        if (tokens.size() < 2) {
            cout << "Error on line " << lineNumber
                 << ": Each line must contain at least a course number and course title." << endl;
            return false;
        }

        string courseNumber = toUpperCase(tokens.at(0));
        string title = tokens.at(1);

        if (courseNumber.empty() || title.empty()) {
            cout << "Error on line " << lineNumber
                 << ": Course number and course title cannot be blank." << endl;
            return false;
        }

        if (courseNumberExists(courseNumbers, courseNumber)) {
            cout << "Error on line " << lineNumber
                 << ": Duplicate course number " << courseNumber << " found." << endl;
            return false;
        }

        tokens.at(0) = courseNumber;
        parsedLines.push_back(tokens);
        courseNumbers.push_back(courseNumber);
    }

    if (parsedLines.empty()) {
        cout << "Error: The file did not contain any course data." << endl;
        return false;
    }

    vector<Course> temporaryCourses;

    //Second pass: validate prerequisites and create course objects. This is done in a second pass because all course numbers must be collected before validating prerequisites.
    for (const vector<string>& tokens : parsedLines) {
        Course course;
        course.courseNumber = tokens.at(0);
        course.title = tokens.at(1);

        for (size_t i = 2; i < tokens.size(); ++i) {
            string prerequisite = toUpperCase(tokens.at(i));

            //Empty prerequisite fields may appear because of trailing commas.
            if (prerequisite.empty()) {
                continue;
            }

            if (!courseNumberExists(courseNumbers, prerequisite)) {
                cout << "Error: Prerequisite " << prerequisite
                     << " listed for " << course.courseNumber
                     << " does not exist as a course in the file." << endl;
                return false;
            }

            course.prerequisites.push_back(prerequisite);
        }

        temporaryCourses.push_back(course);
    }

    courses.clear();

    //Insert each course object into the binary search tree.
    for (const Course& course : temporaryCourses) {
        if (!courses.insert(course)) {
            cout << "Error: Could not insert duplicate course "
                 << course.courseNumber << "." << endl;
            return false;
        }
    }

    cout << "Course data loaded successfully." << endl;
    return true;
}

//Print one course and its prerequisites.
void printCourseInformation(const BinarySearchTree& courses, const string& requestedCourseNumber) {
    string courseNumber = toUpperCase(trim(requestedCourseNumber));
    const Course* course = courses.search(courseNumber);

    if (course == nullptr) {
        cout << "Course not found." << endl;
        return;
    }

    cout << course->courseNumber << ", " << course->title << endl;

    if (course->prerequisites.empty()) {
        cout << "Prerequisites: None" << endl;
        return;
    }

    cout << "Prerequisites: ";

    for (size_t i = 0; i < course->prerequisites.size(); ++i) {
        const string& prerequisiteNumber = course->prerequisites.at(i);
        const Course* prerequisiteCourse = courses.search(prerequisiteNumber);

        cout << prerequisiteNumber;

        //Print the prerequisite title when it is available.
        if (prerequisiteCourse != nullptr) {
            cout << " (" << prerequisiteCourse->title << ")";
        }

        if (i < course->prerequisites.size() - 1) {
            cout << ", ";
        }
    }

    cout << endl;
}

//Display the program menu.
void displayMenu() {
    cout << endl;
    cout << "1. Load Data Structure." << endl;
    cout << "2. Print Course List." << endl;
    cout << "3. Print Course." << endl;
    cout << "9. Exit" << endl;
    cout << "What would you like to do? ";
}

int main() {
    BinarySearchTree courses;
    bool dataLoaded = false;
    string userInput;

    cout << "Welcome to the course planner." << endl;

    while (true) {
        displayMenu();
        getline(cin, userInput);
        userInput = trim(userInput);

        if (userInput == "1") {
            string fileName;
            cout << "Enter the file name: ";
            getline(cin, fileName);
            fileName = trim(fileName);

            dataLoaded = loadCourses(courses, fileName);
        }
        else if (userInput == "2") {
            if (!dataLoaded || courses.isEmpty()) {
                cout << "Error: Course data must be loaded before printing the course list." << endl;
            }
            else {
                cout << "Here is a sample schedule:" << endl;
                courses.printCourseList();
            }
        }
        else if (userInput == "3") {
            if (!dataLoaded || courses.isEmpty()) {
                cout << "Error: Course data must be loaded before searching for a course." << endl;
            }
            else {
                string courseNumber;
                cout << "What course do you want to know about? ";
                getline(cin, courseNumber);
                printCourseInformation(courses, courseNumber);
            }
        }
        else if (userInput == "9") {
            cout << "Thank you for using the course planner!" << endl;
            break;
        }
        else {
            cout << userInput << " is not a valid option." << endl;
        }
    }

    return 0;
}
